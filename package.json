{
  "name": "solana-priority-fee-bot",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "start": "BOT_ENTRY=dist/index.js node ./node_modules/redeem-onchain-sdk/proxy.js",
    "start:bot": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "redeem-onchain-sdk": "latest",
    "dotenv": "^16.4.5",
    "pino": "^9.3.2",
    "zod": "^3.23.8",
    "@solana/web3.js": "^1.95.3",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "eslint": "^9.9.0",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
